dns {
    ipversion_prefer: 4
    upstream {
        alidns: 'quic://dns.alidns.com:853'
        google: 'tls://dns.google:853'
    }
    routing {
        request {
            qname(geosite:cn) -> alidns
            fallback: google
        }
    }
}

group {
    proxy {
        filter: subtag(glados) && name(keyword: 'TW')
        filter: name(regex: '德国N2', regex: '美国R3')
        policy: min_moving_avg
    }
}

routing {
    pname(NetworkManager, systemd-resolved, dnsmasq) -> must_direct
    dip(224.0.0.0/3) -> direct
    dip(255.255.255.255/32) -> direct
    dip('ff00::/8') -> direct
    dip(geoip:private) -> direct
    l4proto(udp) && dport(123) -> direct
    domain(connectivitycheck.gstatic.com) -> direct
    domain(msftconnecttest.com) -> direct
    dip(geoip:cn) -> direct
    domain(geosite:cn) -> direct
    fallback: proxy
}
